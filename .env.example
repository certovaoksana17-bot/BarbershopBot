# Telegram bot token from @BotFather
BOT_TOKEN=123456789:AAAA-your-telegram-bot-token

# Groq API key from https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key
GROQ_MODEL=llama-3.1-8b-instant

# Google Apps Script web app URL (Deploy → Web app → exec URL)
SHEETS_WEB_APP_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# Redis (Upstash / Redis Cloud) — required, no in-memory sessions
REDIS_URL=rediss://default:password@your-redis-host:6379

# Optional admin override code
ADMIN_SECRET_CODE=admin_super_secret

# Master secret codes (login) and Telegram chat IDs (notifications)
MASTER_ANNA_CODE=anna2024
MASTER_ANNA_CHAT_ID=123456789
MASTER_IVAN_CODE=ivan2024
MASTER_IVAN_CHAT_ID=123456789
MASTER_OKSANA_CODE=oksana2024
MASTER_OKSANA_CHAT_ID=123456789

# Webhook (Vercel production)
WEBHOOK_PATH=/api/webhook
WEBHOOK_DOMAIN=your-project.vercel.app

# Local dev only: polling | production: webhook
BOT_MODE=polling

# Optional cron auth for /api/reminders (Vercel Cron)
CRON_SECRET=your_random_secret

# Salon timezone offset from UTC (e.g. 5 for UTC+5 / Екатеринбург)
BOOKING_UTC_OFFSET=5
